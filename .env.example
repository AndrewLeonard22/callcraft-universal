# Copy to .env (gitignored) and fill in. NEVER commit .env — this repo is PUBLIC.
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
# Google Maps Platform key (badass-map tier) — referrer-restricted, deploy-time env only:
VITE_GOOGLE_MAPS_API_KEY=""
# Optional: a vector Map ID (Cloud Console) unlocks 45° tilt for prod; DEMO_MAP_ID works meanwhile.
VITE_GOOGLE_MAPS_MAP_ID=""

# ── SERVER-side keys (Vercel /api functions only — NOT VITE_ prefixed, never in the client bundle).
# Vercel serverless functions read these from process.env directly (no .env-append hack needed).
# RentCast AVM (home values) — /api/home-value. Andrew: rentcast.io → API key + ACTIVATE the subscription.
RENTCAST_API_KEY=""
# Gemini image model (AI yard visualizer) — /api/visualize. Andrew: aistudio.google.com/apikey (+ billing on).
GEMINI_API_KEY=""
# Google Static Maps for the visualizer's server-side satellite fetch. MUST be a SERVER key that is NOT
# referrer-restricted (a server has no referer → a referrer-restricted key returns REQUEST_DENIED). Use an
# IP-restricted (Vercel egress) or unrestricted key limited to Static Maps API + a quota cap.
MAPS_SERVER_KEY=""
